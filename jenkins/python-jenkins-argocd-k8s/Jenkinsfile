pipeline {
    agent any

    environment {
        IMAGE_NAME = "gunjan-django-app"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        // FIXED: Combined your personal folder with the application folder path
        SUB_DIR    = "jenkins/python-jenkins-argocd-k8s/app" 
        // This targets the exact directory on your server using Jenkins Workspace variable
        APP_PATH   = "${WORKSPACE}/jenkins/python-jenkins-argocd-k8s"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }
        
        stage('Debug Folder Structure') {
            steps {
                echo "=== PRINTING ALL FILES IN YOUR REPOSITORY ==="
                sh "ls -R"
                echo "============================================="
            }
        }
        
        stage('Build Local Docker Image') {
            steps {
                dir("${SUB_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }
    } // <-- The stages block ends completely here

    post { // <-- The post block is now in its proper home outside of stages
        success { 
            echo "Successfully built local image -> ${IMAGE_NAME}:${IMAGE_TAG}" 
        }
        failure { 
            echo "Pipeline failed. Check logs." 
        }
    }
}
