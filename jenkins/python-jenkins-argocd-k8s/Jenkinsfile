pipeline {
    agent any

    environment {
        IMAGE_NAME = "gunjan-django-app"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        // FIXED: Using the exact folder string confirmed by your build logs
        SUB_DIR    = "jenkins/python-jenkins-argocd-k8s" 
    }

    stages {
        stage('Validate Syntax') {
            steps {
                echo "Validating Jenkinsfile structure..."
                // Basic check to ensure the file can be read natively
                sh "node -v || echo 'Moving to next step...'"
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }
        
        stage('Debug Folder Structure') {
            steps {
                echo "=== PRINTING ALL FILES IN YOUR REPOSITORY ==="
                sh "ls -R"
                echo "============================================="
            }
        }
        
        stage('Build Local Docker Image') {
            steps {
                script {
                    // 1. Find the exact folder containing the Dockerfile dynamically
                    def dockerfilePath = sh(script: "find . -name Dockerfile -exec dirname {} \\;", returnStdout: true).trim()
                    
                    if (!dockerfilePath) {
                        error "CRITICAL ERROR: Could not find any file named 'Dockerfile' in your repository!"
                    }
                    
                    echo "Found Dockerfile inside directory: ${dockerfilePath}"
                    
                    // 2. Step into that specific directory dynamically and build
                    dir("${dockerfilePath}") {
                        sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    }
                }
            }
        }
    } // <-- The stages block ends cleanly here

    post { 
        success { 
            echo "Successfully built local image -> ${IMAGE_NAME}:${IMAGE_TAG}" 
        }
        failure { 
            echo "Pipeline failed. Check logs." 
        }
    }
}
