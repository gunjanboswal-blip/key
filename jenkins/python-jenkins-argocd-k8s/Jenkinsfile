pipeline {
    agent any 
    environment {
        GITHUB_USER  = 'gunjanboswal-blip'
        REPO_NAME    = 'key'
        PROJECT_DIR  = 'jenkins/python-jenkins-argocd-k8s'
        IMAGE_NAME   = 'my-local-app'
        IMAGE_TAG    = "${BUILD_NUMBER}"
        CREDS_ID     = 'github-token'
    }
    stages {
        stage('Checkout Code') {
            steps {
                git credentialsId: "${CREDS_ID}",
                    url: "https://github.com/${GITHUB_USER}/${REPO_NAME}.git",
                    branch: 'master'
            }
        }
        stage('Build Docker Image') {
            steps {
                script {
                    dir("${PROJECT_DIR}") {
                        sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    }
                }
            }
        }
        stage('Update Manifest & Push') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${CREDS_ID}", passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                        dir("${PROJECT_DIR}") {
                            sh "sed -i 's|image: .*|image: ${IMAGE_NAME}:${IMAGE_TAG}|g' deploy/deploy.yaml"
                        }
                        sh """
                        git config user.email "gunjanboswal.devops@example.com"
                        git config user.name "Gunjan Automation Bot"
                        git add ${PROJECT_DIR}/deploy/deploy.yaml
                        git commit -m "chore: auto-update deployment manifest to v${IMAGE_TAG} [skip ci]"
                        git push https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/${GITHUB_USER}/${REPO_NAME}.git HEAD:master
                        """                        
                    }
                }
            }
        }
    }
}
