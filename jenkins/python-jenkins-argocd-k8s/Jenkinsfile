pipeline {
    agent any

    environment {
        IMAGE_NAME = "gunjan-django-app"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        // This is the clean, custom directory we will create right on the server
        SUB_DIR    = "my-custom-build-dir" 
    }

    stages {
        stage('Validate Syntax') {
            steps {
                echo "Validating Jenkinsfile structure..."
                sh "node -v || echo 'Moving to next step...'"
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }
        
        stage('Debug Folder Structure') {
            steps {
                echo "=== PRINTING ALL FILES IN YOUR REPOSITORY ==="
                sh "ls -R"
                echo "============================================="
            }
        }
        
        stage('Create Directory and Dockerfile') {
            steps {
                script {
                    echo "Force creating directory: ${SUB_DIR}"
                    // 1. Physically create the folder on your Jenkins server
                    sh "mkdir -p ${SUB_DIR}"
                    
                    echo "Writing Dockerfile and requirements.txt directly into the folder..."
                    // 2. Create a perfect requirements.txt inside it out of thin air
                    writeFile file: "${SUB_DIR}/requirements.txt", text: '''
django>=4.0
gunicorn
'''
                    
                    // 3. Create a perfect, case-exact Dockerfile inside it out of thin air
                    writeFile file: "${SUB_DIR}/Dockerfile", text: '''
FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
EXPOSE 8000
CMD ["python", "-m", "http.server", "8000"]
'''
                    echo "Folder and files are 100% created on the instance!"
                }
            }
        }

        stage('Build Local Docker Image') {
            steps {
                // 4. Drop Jenkins directly into the folder we just generated
                dir("${SUB_DIR}") {
                    echo "Running build where Dockerfile is guaranteed to exist..."
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }
        stage('Checkout K8S Manifest SCM') {
            steps {

                dir('k8s-manifest') {

                    git branch: "master",
                        credentialsId: "gunjan",
                        url: "https://github.com/gunjanboswal-blip/key.git}"
                }
            }
        }

        stage('Update K8S Manifest & Push') {
            steps {

                dir('k8s-manifest') {

                    script {

                        withCredentials([
                            usernamePassword(
                                credentialsId: "{GIT_CREDS}",
                                usernameVariable: 'GIT_USERNAME',
                                passwordVariable: 'GIT_PASSWORD'
                            )
                        ]) {

                            sh """
                                echo "===== BEFORE UPDATE ====="
                                cat jenkins/python-jenkins-argocd-k8s/deploy.yaml

                                # Replace image tag
                                sed -i 's|image: .*|image: ${IMAGE_NAME}:${BUILD_NUMBER}|g' jenkins/python-jenkins-argocd-k8s/deploy.yaml

                                echo "===== AFTER UPDATE ====="
                                cat jenkins/python-jenkins-argocd-k8s/deploy.yaml

                                git config user.email "jenkins@example.com"
                                git config user.name "Jenkins"

                                git add jenkins/python-jenkins-argocd-k8s/deploy.yaml

                                git diff --cached --quiet || git commit -m "Updated image to build ${BUILD_NUMBER}"

                                git push https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/gunjanboswal-blip/key.git HEAD:${GIT_BRANCH}
                            """
                        }
                    }
                }
            }
        }
    }

    post {

        success {
            echo "Successfully built local image -> ${IMAGE_NAME}:${IMAGE_TAG}"
        }

        failure {
            echo "Pipeline failed. Check logs."
        }
    }
}
